# Copy this file to .env and fill values. DO NOT commit real tokens.

#########################
# Bot credentials
#########################
# Public (production) bot token (used by `npm start`)
TOKEN_PUBLIC=
# Development/private bot token (used by `npm run start:dev`)
TOKEN_DEV=
# Optional: choose profile explicitly (values: "public" or "dev").
# If set, `BOT_PROFILE` takes precedence over NODE_ENV when selecting bot.*.json
BOT_PROFILE=dev

# Optional client id (used by deploy scripts)
CLIENT_ID=
# Optional dev guild for fast command registration
GUILD_ID=

#########################
# Database
#########################
# Postgres URL; if unset, development falls back to local sqlite
DATABASE_URL=

#########################
# Logging / monitoring
#########################
LOG_LEVEL=info
# Force ANSI color codes in consoles that don't expose a TTY (set to 1 to enable)
LOG_FORCE_COLOR=1
SENTRY_DSN=

#########################
# Deployment helpers
#########################
# Allow global registration when running deploy-commands (set on CI/host)
ALLOW_GLOBAL_REGISTRATION=false
# Auto-run public global deploy on host startup (opt-in)
AUTO_DEPLOY_PUBLIC=false
# Auto-run dev guild deploy on local startup (opt-in)
DEV_AUTO_DEPLOY=false

#########################
# Redis (optional)
#########################
# AUTO_START_REDIS: when set to 1 for development scripts, the bot may try
# to auto-start Redis (Docker or local redis-server) and wait for readiness.
AUTO_START_REDIS=0
# When set to 1|true|yes, startup will fail if Redis is not reachable.
REDIS_REQUIRED=0
# Optional explicit Redis connection URL (overrides host/port/password)
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional Papertrail logging
PAPERTRAIL_HOST=
PAPERTRAIL_PORT=
